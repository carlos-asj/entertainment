{
  "name": "express",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "npm run services:up && npm run migrate:up && node server.js",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "migrate:up": "node-pg-migrate -m infra/migrations up",
    "migrate:down": "node-pg-migrate -m infra/migrations down",
    "migrate:create": "node-pg-migrate -m infra/migrations create"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0"
  }
}
